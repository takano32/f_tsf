---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SampleOverlay from '../components/SampleOverlay.astro';
import AgeGate from '../components/AgeGate.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogUrl: string;
  ogImage: string;
  bodyClass: string;
  page: 'home' | 'announce';
  focusSection: string;
}

const { title, description, canonical, ogUrl, ogImage, bodyClass, page, focusSection } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: ogUrl,
  description,
  inLanguage: ['ja', 'en'],
  image: ogImage,
  isPartOf: { '@type': 'WebSite', name: 'TSFのF', url: 'https://ftsf.me/' },
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="description" content={description} />
    <meta name="keywords" content="TSFのF, TSF, 空想的性転換, 同人サークル, FANZA, DLsite" />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="favicon.ico" sizes="any" />
    <link rel="icon" href="favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="favicon.png" />
    <meta name="theme-color" content="#14110D" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,700..800&family=Martian+Mono:wght@400..700&family=Murecho:wght@400..600&family=Zen+Old+Mincho:wght@600;900&display=swap"
      rel="stylesheet"
    />
    <meta property="og:site_name" content="TSFのF" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-WV8DKYNT45" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-WV8DKYNT45');
    </script>
  </head>
  <body class={bodyClass} data-focus-section={focusSection}>
    <SiteHeader page={page} />
    <main id="top">
      <section class="hero band-ink" aria-label="TSFのF">
        <div class="hero-ticker" aria-hidden="true">
          <span>TSFのF —— 空想的性転換 —— TSF —— 校正刷 —— FANTASY GENDER TRANSFORMATION —— </span>
          <span>TSFのF —— 空想的性転換 —— TSF —— 校正刷 —— FANTASY GENDER TRANSFORMATION —— </span>
        </div>
        <span class="hero-watermark" aria-hidden="true">F</span>
        <div class="hero-inner">
          <p class="hero-kicker">校正刷 / PROOF SHEET — DOUJIN CIRCLE</p>
          <h1 class="hero-title"><span class="hero-title-main">TSFのF</span><span class="hero-title-mark" aria-hidden="true">✛</span></h1>
          <p class="page-lead" data-ja="空想的性転換（ＴＳＦ）作品を制作している同人サークル『ＴＳＦのＦ』のリンク集です。" data-en="A link hub for TSF no F, a doujin circle creating fictional gender transformation (TSF) works.">空想的性転換（ＴＳＦ）作品を制作している同人サークル『ＴＳＦのＦ』のリンク集です。</p>
        </div>
      </section>
      <slot />
    </main>
    <SampleOverlay />
    <AgeGate />
    <footer class="footer">
      <small>&copy; TSFのF. All rights reserved.</small>
      <small class="affiliate-note" data-ja="このページにはアフィリエイトリンクを含みます。" data-en="This page contains affiliate links.">このページにはアフィリエイトリンクを含みます。</small>
    </footer>
    <script src="../scripts/site.ts"></script>
  </body>
</html>

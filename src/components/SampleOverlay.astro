<div class="sample-overlay" id="sampleOverlay">
  <div class="sample-backdrop" data-sample-close></div>
  <div class="sample-dialog">
    <div class="sample-header">
      <h2 id="sampleTitle">サンプル</h2>
      <button class="sample-close" data-sample-close>×</button>
    </div>
    <div class="sample-stage" id="sampleStage" tabindex="0">
      <button class="sample-nav-zone sample-prev-zone" data-sample-prev></button>
      <figure class="sample-page-current" id="sampleCurrentPage">
        <img id="sampleCurrentImage" alt="" />
        <figcaption id="sampleCounter"></figcaption>
      </figure>
      <button class="sample-nav-zone sample-next-zone" data-sample-next></button>
    </div>
    <div class="sample-controls">
      <button class="sample-control" data-sample-prev data-ja="前へ" data-en="Previous">前へ</button>
      <p class="sample-help" data-ja="画像の左側クリックで前ページ、右側クリックで次ページへ移動します。" data-en="Click the left side for previous, right side for next.">画像の左側クリックで前ページ、右側クリックで次ページへ移動します。</p>
      <button class="sample-control" data-sample-next data-ja="次へ" data-en="Next">次へ</button>
    </div>
  </div>
</div>
